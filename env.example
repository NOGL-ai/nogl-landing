# AI Models
# Priority order: MASTRA_OPENAI_API_KEY > NOGL_OPENAI_API_KEY > OPENAI_API_KEY
MASTRA_OPENAI_API_KEY=sk-proj-...  # Recommended: Mastra-specific, won't conflict
# NOGL_OPENAI_API_KEY=sk-proj-...  # Alternative: Project-specific
# OPENAI_API_KEY=sk-proj-...       # Fallback: Standard (may get overridden)
ANTHROPIC_API_KEY=sk-ant-...  # Optional fallback

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# NextAuth
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Magic-link signin (NextAuth EmailProvider) — Stalwart submission relay
# Stalwart relays through Brevo for outbound delivery. Falls back to
# EMAIL_SERVER_* vars below if STALWART_* is unset.
STALWART_HOST=10.10.10.101
STALWART_SUBMISSION_PORT=587
STALWART_ALERTS_USER=alerts@nogl.tech
STALWART_ALERTS_PASSWORD=               # populate from Infisical /apps/STALWART_ALERTS_PASSWORD
STALWART_ALERTS_FROM=alerts@nogl.tech

# Legacy direct-SMTP fallback (used by the password-reset / verification
# templates in src/lib/email.ts when Stalwart isn't configured).
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=

# Analytics (Optional)
ENABLE_COPILOT_ANALYTICS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# Market Intelligence API
MARKET_INTELLIGENCE_API_URL=https://v1-market-intelligence-api-351041537979.europe-west3.run.app
MARKET_INTELLIGENCE_API_KEY=KVN8ejz-pgz-hpd6bvr
QDRANT_HOST=https://vectorize.callapro.ai
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=internal_collection_jng

# Remove these (no longer needed with Mastra)
# N8N_WEBHOOK_URL=
# N8N_API_KEY=

# Mapbox GL JS
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_token_here

# Get your token at: https://account.mapbox.com/access-tokens/
# Free tier: 50,000 map loads/month


# BullMQ (ads-events pipeline) — self-hosted Redis at CT 214 on pve04
# Isolated on a dedicated DB number so other services cannot collide.
REDIS_URL=redis://:password@10.10.10.214:6379
REDIS_DB_BULLMQ=5
