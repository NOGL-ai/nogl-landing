# SCRAPYD_URL=http://<CT178-tailscale-ip>:6800
# SCRAPYD_PROJECT=default
# SCRAPYD_SPIDER=universal
SCRAPER_DATABASE_URL=postgresql://user:pass@host:5432/fashion_rag

# -- Marketing Assets pipeline --
# Redis / BullMQ
REDIS_URL=redis://:password@10.10.10.214:6379/0

# Cloudflare R2 (storage for captured assets)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nogl-marketing-assets
R2_PUBLIC_URL=

# Apify (primary for IG/YouTube/TikTok, fallback for Meta Ads)
APIFY_TOKEN=apify_api_xxx
APIFY_WEBHOOK_SECRET=change-me-to-a-long-random-string
APIFY_META_ADS_TASK_ID=
APIFY_GOOGLE_ADS_TASK_ID=
APIFY_TIKTOK_ADS_TASK_ID=
APIFY_INSTAGRAM_TASK_ID=

# Public origin (used for Apify webhook callback URL)
PUBLIC_URL=

# IMAP ingestion (operator activates when newsletters are subscribed)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_INBOX=INBOX

# VLM aesthetic scoring (reuses OPENAI_API_KEY)
AESTHETIC_VLM_PROVIDER=openai

# Qdrant (reused from existing config; collection created on first insert)
QDRANT_URL=
QDRANT_API_KEY=
# Vercel Cron secret — set same value in Vercel env vars
CRON_SECRET=changeme

# Ad Creative Scoring Service (CT 184 homelab / production endpoint)
AD_SCORING_API_URL=http://10.10.10.184:8000
# AD_SCORING_API_KEY=                    # optional; set if the service has key auth enabled
# NEXT_PUBLIC_AD_SCORING_API_URL=        # client-side override (defaults to AD_SCORING_API_URL)
