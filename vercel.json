{
  "buildCommand": "npm run build",
  "installCommand": "npm install --include=optional",
  "outputDirectory": ".next-build",
  "framework": "nextjs",
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  },
  "crons": [
    {
      "path": "/api/cron/bridge-scraped-items",
      "schedule": "*/30 * * * *"
    }
  ]
}
