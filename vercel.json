{
  "buildCommand": "npm run build",
  "installCommand": "npm install --include=optional",
  "outputDirectory": ".next-build",
  "framework": "nextjs",
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  },
  "crons": [
    { "path": "/api/cron/refresh-trends", "schedule": "0 3 * * *" }
  ]
}
