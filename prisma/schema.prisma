model public_sync_state {
  store_id    BigInt   @id
  last_cutoff DateTime @default(dbgenerated("'1970-01-01 00:00:00+00'::timestamp with time zone")) @db.Timestamptz(6)

  @@map("sync_state")
  @@schema("public")
}

enum CompetitorStatus {
  ACTIVE
  INACTIVE
  MONITORING
  PAUSED
  ARCHIVED

  @@schema("nogl")
}

enum CompanyTrackingStatus {
  UNTRACKED
  TRACKED
  PAUSED

  @@schema("nogl")
}

enum UserRole {
  USER
  EXPERT
  ADMIN

  @@schema("nogl")
}

enum public_UserRole {
  USER
  EXPERT
  ADMIN

  @@map("UserRole")
  @@schema("public")
}

// ─── Alerts schema ──────────────────────────────────────────────────────────

enum AlertSeverity {
  HOT
  WARM
  COLD
  SNOOZED
  RESOLVED

  @@schema("alerts")
}

enum AlertStatus {
  OPEN
  SNOOZED
  RESOLVED
  DISMISSED

  @@schema("alerts")
}

enum AlertType {
  // CMO types
  PRICE_DROP
  PRICE_INCREASE
  COMPETITOR_NEW_PRODUCT
  COMPETITOR_STOCKOUT
  PROMO_START
  PROMO_END
  AD_CREATIVE_CHANGE
  NEWSLETTER_RECEIVED
  // CFO types
  STOCKOUT_IMMINENT
  LOW_INVENTORY
  REORDER_POINT_HIT
  OVERSTOCK
  STOCKOUT_ACTIVE
  LEAD_TIME_BREACH
  SUPPLIER_DELAY

  @@schema("alerts")
}

enum AlertAudience {
  CMO
  CFO

  @@schema("alerts")
}

model Alert {
  id                  String        @id @default(cuid())
  companyId           String
  audience            AlertAudience
  type                AlertType
  severity            AlertSeverity
  status              AlertStatus   @default(OPEN)
  title               String
  description         String?
  subjectProductId    String?
  subjectVariantId    String?
  subjectCompetitorId String?
  estimatedImpact     Float?
  impactCurrency      String        @default("EUR")
  impactWindowDays    Int           @default(180)
  metadata            Json          @default("{}")
  assignedToUserId    String?
  snoozeUntil         DateTime?
  resolvedAt          DateTime?
  resolvedByUserId    String?
  triggeredAt         DateTime      @default(now())
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([companyId, audience, status, severity, triggeredAt])
  @@index([subjectProductId])
  @@index([type])
  @@schema("alerts")
}

model AlertSubscription {
  id         String        @id @default(cuid())
  userId     String
  companyId  String
  audience   AlertAudience
  alertType  AlertType
  enabled    Boolean       @default(true)
  digestMode String        @default("REALTIME")
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([userId, companyId, audience, alertType])
  @@schema("alerts")
}

// ─── Forecast schema ─────────────────────────────────────────────────────────

model ForecastTenant {
  id           String   @id @default(cuid())
  companyId    String   @unique
  magicNumber  Float    @default(1.0)
  hasBundle    Boolean  @default(false)
  isDemoTenant Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  saleChannels ForecastSaleChannel[]
  products     ForecastProduct[]
  annotations  ForecastAnnotation[]
  purchaseOrders ReplenishmentPurchaseOrder[]
  suppliers    ReplenishmentSupplier[]

  @@schema("forecast")
}

model ForecastSaleChannel {
  id       String   @id @default(cuid())
  tenantId String
  name     String
  label    String
  colorFg  String
  colorBg  String
  weight   Float    @default(1.0)
  createdAt DateTime @default(now())

  tenant          ForecastTenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  historicalSales ForecastHistoricalSale[]
  quantiles       ForecastQuantile[]

  @@unique([tenantId, name])
  @@schema("forecast")
}

model ForecastProduct {
  id           String   @id @default(cuid())
  tenantId     String
  externalId   String?
  productTitle String
