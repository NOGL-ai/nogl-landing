{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["next", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Next.js Dev Server (clean)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:clean"],
      "port": 3000
    },
    {
      "name": "Prisma Studio",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "db:studio"],
      "port": 5555
    },
    {
      "name": "Stripe Webhook Listener",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "stripe:listen"],
      "port": 3000
    }
  ]
}
