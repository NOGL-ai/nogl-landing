{
  "name": "meta-ads-library-scraper",
  "version": "2.0.0",
  "description": "Advanced Meta Ads Library scraper with 2025 anti-detection capabilities and GraphQL interception",
  "main": "src/main.js",
  "scripts": {
    "start": "node src/main.js",
    "lint": "eslint \"src/**/*.js\" \"utils/**/*.js\" \"tests/**/*.js\"",
    "test": "node --test 'tests/**/*.test.js'"
  },
  "keywords": [
    "apify",
    "actor",
    "scraping",
    "facebook",
    "meta",
    "ads",
    "library"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "apify": "^3.4.0",
    "better-sqlite3": "^11.7.0",
    "crawlee": "^3.13.0",
    "playwright": "^1.59.0",
    "cheerio": "^1.0.0",
    "axios": "^1.8.0",
    "user-agents": "^1.1.0",
    "proxy-agent": "^6.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0"
  },
  "overrides": {
    "glob": "^10.3.0",
    "rimraf": "^5.0.0",
    "inflight": "^1.0.6"
  },
  "apify": {
    "actorSpecification": 1,
    "name": "meta-ads-library-scraper",
    "title": "Meta Ads Library Scraper",
    "description": "Extract comprehensive data from Meta (Facebook) Ads Library with advanced anti-detection",
    "version": "1.0",
    "storages": {
      "dataset": {
        "actorSpecification": 1,
        "title": "Meta Ads Data",
        "views": {
          "overview": {
            "title": "Overview",
            "transformation": {
              "fields": [
                "adId",
                "pageId",
                "pageName",
                "adContent",
                "startDate",
                "endDate",
                "spend",
                "impressions",
                "reach"
              ]
            }
          }
        }
      }
    }
  }
}